data_fid <- readRDS(here("vistas/informediario/data/tabla_soloFID_resumen_pordia_municipio_turno_completo.rds"))
# 2. Preparar lista de fechas única y ordenada (Inverso)
fechas_unicas <- sort(unique(c(data_im$Fecha, data_fid$Fecha)), decreasing = TRUE)
# 3. Convertir a texto para evitar problemas de formato en JS
data_im$Fecha  <- as.character(data_im$Fecha)
data_fid$Fecha <- as.character(data_fid$Fecha)
# 4. PASAR DATOS A OJS
# Importante: NO uses library(quarto) ni quarto::ojs_define.
# Solo ojs_define() a secas. Solo funcionará al hacer RENDER.
ojs_define(
im_raw = data_im,
fid_raw = data_fid,
lista_fechas = as.character(fechas_unicas)
)
