ver <- historico_llenado %>%
filter(Fecha >= "2026-01-01") %>%
filter(Municipio == "B") %>%
filter(Condicion %in% c("Basura Afuera", "Escombro", "Poda"))
View(ver)
df_conteo <- ver %>%
# 2. Agrupamos por gid y contamos (esto crea la columna 'n')
count(gid, name = "total") %>%
# 3. Ordenamos de mayor a menor según la columna 'total'
arrange(desc(total))
View(df_conteo)
names(df_conteo)
df_conteo <- ver %>%
# Agrupamos por todas estas columnas a la vez
count(gid, Circuito, Posicion, Direccion, Condicion, name = "total") %>%
# Ordenamos de mayor a menor
arrange(desc(total))
View(df_conteo)
df_conteo <- ver %>%
# Agrupamos por todas estas columnas a la vez
count(gid, Circuito, Direccion, Condicion, name = "total") %>%
# Ordenamos de mayor a menor
arrange(desc(total))
View(df_conteo)
df_conteo <- ver %>%
filter(Condicion %in% c("Basura Afuera", "Escombro", "Poda")) %>%
group_by(gid) %>%
summarise(
total = n(),
Circuito = first(Circuito),
Posicion = first(Posicion),
Direccion = first(Direccion),
Condicion = first(Condicion),
the_geom = first(the_geom)
) %>%
arrange(desc(total))
View(df_conteo)
df_conteo <- ver %>%
group_by(gid) %>%
summarise(
Denuncias = n(),
Circuito = first(Circuito),
Posicion = first(Posicion),
Direccion = first(Direccion),
the_geom = first(the_geom)
) %>%
arrange(desc(Denuncias))
View(df_conteo)
library(sf)
library(dplyr)
# 1. Convertimos el dataframe a objeto espacial (usando el sistema de la IM)
df_sf <- st_as_sf(df_conteo, wkt = "the_geom", crs = 32721)
# 2. Transformamos al sistema de Google (WGS84)
df_kml <- st_transform(df_sf, crs = 4326) %>%
# Seleccionamos solo las columnas útiles para que el KML no sea pesado
select(gid, Circuito, Direccion, Condicion, total)
library(sf)
library(dplyr)
# 1. Convertimos el dataframe a objeto espacial (usando el sistema de la IM)
df_sf <- st_as_sf(df_conteo, wkt = "the_geom", crs = 32721)
# 2. Transformamos al sistema de Google (WGS84)
df_kml <- st_transform(df_sf, crs = 4326) %>%
# Seleccionamos solo las columnas útiles para que el KML no sea pesado
select(gid, Circuito, Direccion, Denuncias)
# 3. Exportamos a KML
# El argumento 'delete_dsn = TRUE' sirve para sobreescribir el archivo si ya existe
st_write(df_kml, "puntos_limpieza_mvd.kml", driver = "KML", delete_dsn = TRUE)
