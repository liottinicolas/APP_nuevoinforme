puntos_solapados <- st_intersection(capa_recorrido, capa_filtrada_CAPURRO_2) %>%
filter(velocidad <= 5)
temp_path_puntos <- tempfile(fileext = ".geojson")
st_write(puntos_solapados, temp_path_puntos, driver = "GeoJSON")
