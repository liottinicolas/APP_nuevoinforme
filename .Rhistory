drawMapaCompleto_IM <- function(zona_df, col_id = "id", col_label = "muninom") {
# 1. Validar y transformar a WGS84 (vital para Leaflet)
if (st_crs(zona_df)$epsg != 4326) {
zona_ll <- st_transform(zona_df, 4326)
} else {
zona_ll <- zona_df
}
# 2. Construir el mapa
leaflet(zona_ll) %>%
# Fondo oficial de la IM
addWMSTiles(
baseUrl = "https://montevideo.gub.uy/app/geowebcache/service/wms",
layers = "mapstore-base:capas_base",
options = WMSTileOptions(format = "image/png", transparent = TRUE),
group = "Cartografía Base"
) %>%
# Dibujar TODOS los polígonos del DF
addPolygons(
color = "darkgreen",
weight = 2,
fillOpacity = 0.3,
# Usamos las columnas que definas en los argumentos
label = ~as.character(get(col_label)),
popup = ~paste0("<strong>ID:</strong> ", get(col_id), "<br>",
"<strong>Nombre:</strong> ", get(col_label)),
group = "Zonas"
) %>%
# Buscador de direcciones (Corregido con searchOptions)
addSearchOSM(
options = searchOptions(
textPlaceholder = "Buscar dirección...",
collapsed = FALSE
)
) %>%
# Control de capas
addLayersControl(
overlayGroups = c("Zonas"),
options = layersControlOptions(collapsed = FALSE)
)
}
