library(DBI)
library(RPostgres)
library(sf)
# 1. Creamos la conexión (usando los datos de tu cadena de texto)
con <- dbConnect(
RPostgres::Postgres(),
dbname = 'qgis',
host = 'pdbqgistest.imm.gub.uy',
port = 5411,
user = 'qgis',      # El usuario que mencionaste
