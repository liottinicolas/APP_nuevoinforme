rep("", 10),
rep("Haiti", 12)
),
Servicio = c(
rep("Mezclado", 24),
rep("Reciclable", 12)
),
stringsAsFactors = FALSE
)
# Agregar el prefijo "SIM" a la columna Matricula
df_flota$Matricula <- paste0("SIM", df_flota$Matricula)
names(df_flota)
fecha_inicio <- "2026-04-10T13:49:11"
fecha_fin    <- "2026-04-14T13:49:11"
# 2. Aplicamos la función a cada matrícula
