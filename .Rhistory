capa_filtrada_CAPURRO_2 <- capa_intra[capa_intra$nombre == "CAPURRO 2", ] # Ejemplo de filtro
capa_filtrada_CARRASCO_2 <- capa_intra[capa_intra$nombre == "CARRASCO 2", ] # Ejemplo de filtro
