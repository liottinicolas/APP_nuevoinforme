# --- 2. CALCULAR INTERSECCIÓN ---
capa_recorrido <- st_transform(capa_recorrido_original, st_crs(capa_filtrada))
puntos_solapados <- st_intersection(capa_recorrido, capa_filtrada)
if (nrow(puntos_solapados) == 0) {
