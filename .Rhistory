capa_recorrido <- st_read("vistas/mapas/SIM.json")
# --- 2. CALCULAR PUNTOS SUPERPUESTOS (INTERSECCIÓN) ---
# Aseguramos misma proyección
capa_recorrido <- st_transform(capa_recorrido, st_crs(capa_filtrada_CAPURRO_2))
