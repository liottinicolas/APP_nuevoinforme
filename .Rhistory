# Aseguramos misma proyección
capa_recorrido <- st_transform(capa_recorrido, st_crs(capa_filtrada_CARRASCO_3))
# Intersección: Solo los puntos que cayeron dentro de Capurro
puntos_solapados <- st_intersection(capa_recorrido, capa_filtrada_CARRASCO_3)
View(puntos_solapados)
