library(sf)
library(dplyr)
# 1. Tomamos los peores 50
peores_50 <- df_conteo %>%
head(50)
# 2. Convertimos a objeto espacial (Sistema IM)
df_sf <- st_as_sf(peores_50, wkt = "the_geom", crs = 32721)
# 3. Transformamos a WGS84 y renombramos para KML
df_kml <- st_transform(df_sf, crs = 4326) %>%
mutate(
Name = as.character(gid),        # El GID será el título del punto
Description = as.character(Direccion) # La Dirección será el texto principal
) %>%
# Seleccionamos Name, Description y cualquier otra que quieras que aparezca en la tabla de datos
select(Name, Description, Circuito, Denuncias)
# 4. Exportamos a KML
st_write(df_kml, "puntos_limpieza_mvd.kml", driver = "KML", delete_dsn = TRUE)
View(df_conteo)
ver <- historico_llenado %>%
filter(Fecha >= "2026-01-01") %>%
filter(Municipio == "B") %>%
filter(Condicion %in% c("Basura Afuera", "Escombro", "Poda"))
df_conteo <- ver %>%
group_by(gid) %>%
summarise(
Denuncias = n(),
Circuito = first(Circuito),
Posicion = first(Posicion),
Direccion = first(Direccion),
the_geom = first(the_geom)
) %>%
arrange(desc(Denuncias))
library(sf)
library(dplyr)
# 1. Tomamos los peores 50
peores_50 <- df_conteo %>%
head(50)
View(peores_50)
View(peores_50)
# 2. Convertimos a objeto espacial (Sistema IM)
df_sf <- st_as_sf(peores_50, wkt = "the_geom", crs = 32721)
View(df_kml)
df_conteo <- ver %>%
group_by(gid) %>%
summarise(
Denuncias = n(),
Circuito_corto = first(Circuito_corto),
Posicion = first(Posicion),
Direccion = first(Direccion),
the_geom = first(the_geom)
) %>%
arrange(desc(Denuncias))
View(df_conteo)
df_conteo <- ver %>%
group_by(gid) %>%
summarise(
Denuncias = n(),
Circuito_corto = first(Circuito_corto),
Posicion = first(Posicion),
Direccion = first(Direccion),
the_geom = first(the_geom)
) %>%
arrange(desc(Denuncias)) %>%
rename(Circuito = Circuito_corto)
View(df_conteo)
# 1. Tomamos los peores 50 (asegúrate de que df_conteo tenga estas columnas)
peores_50 <- df_conteo %>%
head(50)
# 2. Convertimos a objeto espacial (Sistema IM)
df_sf <- st_as_sf(peores_50, wkt = "the_geom", crs = 32721)
# 3. Transformamos a WGS84 y personalizamos los campos KML
df_kml <- st_transform(df_sf, crs = 4326) %>%
mutate(
# Name será la combinación de Circuito y Posición
Name = paste(Circuito, Posicion, sep = " - "),
# Description será la Dirección
Description = as.character(Direccion),
# Mantenemos el gid original como un atributo de texto para que no se pierda
gid_attr = as.character(gid)
) %>%
# Seleccionamos Name, Description y el resto de los atributos
# Incluimos 'gid_attr' para que aparezca en la tabla de datos del globo
select(Name, Description, gid = gid_attr, Circuito, Posicion, Denuncias)
View(df_kml)
# 3. Transformamos a WGS84 y personalizamos los campos KML
df_kml <- st_transform(df_sf, crs = 4326) %>%
mutate(
# Name será la combinación de Circuito y Posición
Name = paste(Circuito, Posicion, sep = " - pos "),
# Description será la Dirección
Description = as.character(Direccion),
# Mantenemos el gid original como un atributo de texto para que no se pierda
gid_attr = as.character(gid)
) %>%
# Seleccionamos Name, Description y el resto de los atributos
# Incluimos 'gid_attr' para que aparezca en la tabla de datos del globo
select(Name, Description, gid = gid_attr, Circuito, Posicion, Denuncias)
View(df_kml)
View(df_kml)
ver <- historico_llenado %>%
filter(Fecha >= "2026-01-15") %>%
filter(Fecha <= "2026-02-28") %>%
filter(Municipio == "B") %>%
filter(Condicion %in% c("Basura Afuera", "Escombro", "Poda"))
df_conteo <- ver %>%
group_by(gid) %>%
summarise(
Denuncias = n(),
Circuito_corto = first(Circuito_corto),
Posicion = first(Posicion),
Direccion = first(Direccion),
the_geom = first(the_geom)
) %>%
arrange(desc(Denuncias)) %>%
rename(Circuito = Circuito_corto)
View(df_conteo)
names(df_conteo)
df_conteo_imprimir <- df_conteo %>%
select(Direccion, Circuito, Posicion, Denuncias, gid, the_geom)
View(df_conteo_imprimir)
