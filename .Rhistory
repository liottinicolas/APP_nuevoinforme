drawMapa_IM_Pro <- function(zona_df,
col_id = "id",        # Nombre de la columna que es la clave primaria
col_label = "nombre", # Nombre de la columna que quieres ver en etiquetas
filtro_ids = NULL,    # Si pasas una lista (ej: c(10, 20)), solo dibuja esos
color_relleno = "darkgreen", # Color fijo o nombre de columna para paleta
opacidad = 0.3        # Transparencia del relleno
) {
# --- 1. PREPARACIÓN Y FILTRADO ---
# Hacemos una copia local para no romper el original
data_mapa <- zona_df
# Si el usuario pasó IDs específicos (ej: c(1, 5, 8)), filtramos el dataframe
if (!is.null(filtro_ids)) {
data_mapa <- data_mapa %>%
filter(get(col_id) %in% filtro_ids)
}
# Transformamos a WGS84 para que Leaflet no "tire" los polígonos al océano
data_mapa <- st_transform(data_mapa, 4326)
# --- 2. LÓGICA DE COLORES ---
# Si 'color_relleno' es el nombre de una columna, creamos una paleta automática.
# Si no existe esa columna, usamos el valor como un color fijo (ej: "red").
if (color_relleno %in% names(data_mapa)) {
# Paleta para categorías (colores distintos por cada valor de la columna)
pal <- colorFactor(palette = "Set1", domain = data_mapa[[color_relleno]])
fill_color_final <- ~pal(get(color_relleno))
} else {
fill_color_final <- color_relleno
}
# --- 3. CONSTRUCCIÓN DEL MAPA ---
leaflet(data_mapa) %>%
# Capa base oficial de Montevideo
addWMSTiles(
baseUrl = "https://montevideo.gub.uy/app/geowebcache/service/wms",
layers = "mapstore-base:capas_base",
options = WMSTileOptions(format = "image/png", transparent = TRUE),
group = "Mapa Base IM"
) %>%
addPolygons(
color = "black",        # Color del borde (siempre negro para que resalte)
weight = 1,             # Grosor del borde
fillColor = fill_color_final,
fillOpacity = opacidad,
# get(col_label) permite que busquemos la columna dinámicamente
label = ~as.character(get(col_label)),
popup = ~paste0("<strong>ID:</strong> ", get(col_id), "<br>",
"<strong>Etiqueta:</strong> ", get(col_label)),
group = "Capa Activa"
) %>%
# Buscador de direcciones (OSM)
addSearchOSM(
options = searchOptions(textPlaceholder = "Buscar dirección...", collapsed = FALSE)
) %>%
# Buscador de tus datos (Busca por la columna de ID que definas)
addSearchFeatures(
targetGroups = "Capa Activa",
options = searchFeaturesOptions(zoom = 16, openPopup = TRUE, textPlaceholder = "Buscar por ID...")
) %>%
addLayersControl(
overlayGroups = c("Capa Activa"),
options = layersControlOptions(collapsed = FALSE)
)
}
# Todos
drawMapa_IM_Pro(Vigente_Circuitos_CAP, col_id = "GID", col_label = "CIRCUITO", color_relleno = "orange")
# Imagina que te piden analizar solo los GID 105, 106 y 107
drawMapa_IM_Pro(Vigente_Circuitos_CAP,
col_id = "GID",
col_label = "CIRCUITO",
filtro_ids = c(1, 9, 6),
color_relleno = "red")
# Imagina que te piden analizar solo los GID 105, 106 y 107
drawMapa_IM_Pro(Vigente_Circuitos_CAP,
col_id = "GID",
col_label = "CIRCUITO",
filtro_ids = c(1, 9, 6),
color_relleno = "red")
drawMapa_IM_Pro <- function(zona_df,
col_id = "id",
col_label = "nombre",
filtro_ids = NULL,
color_relleno = "darkgreen",
opacidad = 0.3) {
# 1. FILTRADO Y PREPARACIÓN
data_mapa <- zona_df
if (!is.null(filtro_ids)) {
# Filtramos usando el nombre de columna dinámico
data_mapa <- data_mapa %>% filter(.data[[col_id]] %in% filtro_ids)
}
# Verificación: ¿quedó algo después del filtro?
if (nrow(data_mapa) == 0) {
stop("El filtro no devolvió resultados. Verificá si los IDs existen en la columna seleccionada.")
}
# 2. CREAR COLUMNAS ESTÁTICAS (Esto evita el error de 'type list')
# Extraemos los valores como vectores simples para que leaflet no se confunda
data_mapa$.id_display <- as.character(data_mapa[[col_id]])
data_mapa$.label_display <- as.character(data_mapa[[col_label]])
# Reproyectar a WGS84
data_mapa <- st_transform(data_mapa, 4326)
# 3. LÓGICA DE COLORES
if (color_relleno %in% names(data_mapa)) {
pal <- colorFactor(palette = "Set1", domain = data_mapa[[color_relleno]])
fill_color_final <- pal(data_mapa[[color_relleno]])
} else {
fill_color_final <- color_relleno
}
# 4. CONSTRUCCIÓN DEL MAPA
leaflet(data_mapa) %>%
addWMSTiles(
baseUrl = "https://montevideo.gub.uy/app/geowebcache/service/wms",
layers = "mapstore-base:capas_base",
options = WMSTileOptions(format = "image/png", transparent = TRUE),
group = "Mapa Base IM"
) %>%
addPolygons(
color = "black", weight = 1,
fillColor = fill_color_final,
fillOpacity = opacidad,
# Usamos las columnas estáticas que creamos arriba con ~
label = ~.label_display,
popup = ~paste0("<strong>ID:</strong> ", .id_display, "<br>",
"<strong>Etiqueta:</strong> ", .label_display),
group = "Capa Activa"
) %>%
addSearchOSM(
options = searchOptions(textPlaceholder = "Buscar dirección...", collapsed = FALSE)
) %>%
addSearchFeatures(
targetGroups = "Capa Activa",
options = searchFeaturesOptions(zoom = 16, openPopup = TRUE, textPlaceholder = "Buscar por ID...")
) %>%
addLayersControl(
overlayGroups = c("Capa Activa"),
options = layersControlOptions(collapsed = FALSE)
)
}
drawMapa_IM_Pro(Vigente_Circuitos_CAP, col_id = "GID", col_label = "CIRCUITO", color_relleno = "orange")
Q
