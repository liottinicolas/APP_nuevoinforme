filter(Matricula == matricula_ref) %>%
pull(Servicio)
# Asignamos (si el resultado tiene datos)
if(length(servicio_encontrado) > 0) {
puntos_solapados <- puntos_solapados %>%
mutate(FRACCION = servicio_encontrado[1])
}
